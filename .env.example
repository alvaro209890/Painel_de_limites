# Painel de Limites / Central DevOps Pessoal
# Copie para .env/local do seu processo se quiser sobrescrever caminhos/portas.
# Não coloque valores reais em commits públicos.

# Portas
LIMITS_PANEL_PORT=8787
LIMITS_PANEL_SITE_PORT=4173

# Segurança admin
# Preferencialmente configure via ambiente/PM2/systemd.
# Se não configurar aqui, o backend tenta ler ~/.config/codex-profiles/admin-secret.json
LIMITS_PANEL_ADMIN_PASSWORD=troque-esta-senha
LIMITS_PANEL_SESSION_SECRET=troque-este-segredo-longo-aleatorio

# Codex CLI
CODEX_AUTH_PATH=/home/server/.codex/auth.json
CODEX_STATE_PATH=/home/server/.codex/state_5.sqlite
CODEX_PROFILES_ROOT=/home/server/.config/codex-profiles

# Hermes / este assistente
HERMES_AUTH_PATH=/home/server/.hermes/auth.json
HERMES_CODEX_PROVIDER_KEY=openai-codex

# DeepSeek
# O backend também tenta ler de ~/.hermes/.env
DEEPSEEK_API_KEY=
